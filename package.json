{
  "name": "percentdosegraph",
  "version": "1.0.0",
  "description": "A lightweight clinical dosing visualization tool for pharmacists and clinicians",
  "private": true,
  "license": "MIT",
  "author": "Rafi",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafireadisten/percentdosegraph.git"
  },
  "keywords": [
    "clinical",
    "dosing",
    "medication",
    "pharmacy",
    "healthcare",
    "visualization"
  ],
  "workspaces": [
    "artifacts/api-server",
    "lib/db",
    "lib/api-zod",
    "mobile/app"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run build:web && node scripts/dev-static-server.mjs",
    "dev:api": "npm --workspace @workspace/api-server run dev",
    "db:init": "npm --workspace @workspace/api-server run db:init",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run watch:web\"",
    "build": "npm run build:all",
    "build:web": "esbuild frontend-react/app.js --bundle --format=esm --platform=browser --outfile=frontend-react/app.bundle.js",
    "build:api": "npm --workspace @workspace/api-server run build",
    "build:all": "npm run build:web && npm run build:api",
    "build:deploy": "npm run build:all && mkdir -p deploy && cp frontend-react/app.bundle.js deploy/ && cp frontend-react/index.html deploy/ && cp frontend-react/styles.css deploy/ && cp frontend-react/index.html deploy/404.html",
    "watch:web": "nodemon --watch frontend-react --ext js,css --exec \"npm run build:web\"",
    "start": "npm run dev:full",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix --ignore-path .eslintignore",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vitest": "vitest",
    "test:vitest:ui": "vitest --ui",
    "test:api": "npm --workspace @workspace/api-server run test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lighthouse": "lhci autorun",
    "clean": "rm -rf node_modules/**/dist node_modules/**/build frontend-react/app.bundle.js artifacts/api-server/dist coverage .storybook-out",
    "precommit": "npm run lint && npm run test && npm run build:all",
    "auto-build": "npm run build:all && echo '✅ Auto-build completed successfully'",
    "auto-deploy": "npm run build:deploy && echo '🚀 Auto-deploy to /deploy folder completed'",
    "build:mobile:ios": "echo 'iOS app built - see mobile-apps/ios/README.md'",
    "build:mobile:android": "cd mobile-apps/android && ./gradlew assembleDebug",
    "setup:mobile": "bash scripts/setup-mobile.sh",
    "dev:mobile": "npm --workspace percentdosegraph-mobile run dev",
    "dev:mobile:ios": "npm --workspace percentdosegraph-mobile run dev:ios",
    "dev:mobile:android": "npm --workspace percentdosegraph-mobile run dev:android",
    "build:mobile:production": "npm --workspace percentdosegraph-mobile run build:ios && npm --workspace percentdosegraph-mobile run build:android"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^8.57.1",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "lighthouse": "^13.0.3",
    "nodemon": "^3.1.7",
    "prettier": "^3.8.1",
    "storybook": "^10.3.4",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "vitest": "^4.1.2",
    "workbox-sw": "^7.4.0",
    "workbox-webpack-plugin": "^7.4.0"
  }
}
