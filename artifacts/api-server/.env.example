# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase Auth
# Set these to enable Supabase-backed registration, login, and bearer token validation.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key
SUPABASE_AUTH_EMAIL_REDIRECT_TO=http://localhost:8080/frontend-react/

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database URL (optional, for PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
