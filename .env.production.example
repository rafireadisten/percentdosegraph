# Production Environment Configuration
# IMPORTANT: Keep this file SECRET. Do not commit to version control.
# Create from this template: cp .env.example .env.production

# Node Environment
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# JWT/Auth Secrets (REQUIRED - Generate with: openssl rand -base64 32)
# KEEP THESE SECRET - NEVER COMMIT TO GIT
JWT_SECRET=your-secure-random-32-character-secret-here
AUTH_SECRET=your-secure-auth-secret-here

# Database Configuration
# Option 1: JSON file persistence (default)
DATABASE_URL=

# Option 2: PostgreSQL (uncomment to enable)
# DATABASE_URL=postgresql://user:password@localhost:5432/percentdosegraph

# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Application Settings
# Frontend domain URL when accessed from external clients
FRONTEND_URL=https://dosegraph.com
API_URL=https://api.dosegraph.com

# CORS Origins (comma-separated if multiple)
CORS_ORIGINS=https://dosegraph.com,https://www.dosegraph.com

# Rate Limiting (requests per minute)
RATE_LIMIT=100

# Persistence options: 'json' or 'postgres'
PERSISTENCE_ADAPTER=json

# Seed data on first boot
PERSISTENCE_SEED_ON_BOOT=false

# Email (optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Monitoring (optional)
SENTRY_DSN=
NEW_RELIC_API_KEY=

# Feature Flags
ENABLE_OAUTH=false
ENABLE_POSTGRES_SYNC=false
ENABLE_EXPORT_PDF=true
ENABLE_MOBILE_API=true

# Security
SESSION_SECRET=your-session-secret-here
SECURE_COOKIES=true
SAME_SITE_COOKIES=Strict

# OpenFDA API (optional - for drug interaction checking)
OPENFDA_API_KEY=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# Logging & Monitoring
LOG_FORMAT=json
LOG_DESTINATION=/var/log/pdg/app.log

# Performance
NODE_CLUSTER_WORKERS=auto
MEMORY_LIMIT=512m
